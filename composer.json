{
    "name": "dseguy/genie",
    "description": "Systematic value generation for PHP: lazy, composable, fluent.",
    "type": "library",
    "license": "MIT",
    "keywords": ["generator", "iterator", "combinatorics", "testing", "values"],
    "authors": [
        {
            "name": "Damien Seguy",
            "email": "damien@seguy.org"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Dseguy\\Generator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dseguy\\Generator\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
